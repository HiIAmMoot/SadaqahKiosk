# Gradle build outputs
.gradle/
/build/
/app/build/
**/build/

# Local configuration — contains SDK path, never commit
local.properties

# Android Studio project files
.idea/
*.iml

# macOS metadata
.DS_Store

# NDK / CMake
.externalNativeBuild/
.cxx/

# Kotlin compiler error dumps
.kotlin/

# Release artifacts — build from source, never commit binaries
*.apk
*.aab
app/release/
app/debug/

# Signing keys — NEVER commit these
*.keystore
*.jks
keystore.properties

# Captures (Android Studio profiler recordings)
/captures/
